---
const { title, description } = Astro.props;
const pageTitle = title ? `${title} — 半人马熵减实验室` : '半人马熵减实验室';
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description || '大消费品&零售全球化的组织治理洞察'} />
  <title>{pageTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; -webkit-font-smoothing: antialiased; }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #fafaf8;
      color: #1a1a1a;
      line-height: 1.7;
    }
    article {
      font-family: 'Noto Serif SC', Georgia, serif;
    }
    article h1 { font-family: 'Inter', system-ui, sans-serif; font-weight: 600; }
    article h2, article h3 { font-family: 'Inter', system-ui, sans-serif; font-weight: 600; }
    article p { margin-bottom: 1.25em; }
    article table { width: 100%; border-collapse: collapse; margin: 1.5em 0; font-size: 0.9rem; font-family: 'Inter', system-ui, sans-serif; }
    article th, article td { border: 1px solid #e0dcd5; padding: 0.6em 0.8em; text-align: left; }
    article th { background: #f5f0eb; font-weight: 600; }
    article blockquote {
      border-left: 3px solid #c76b55;
      padding-left: 1em;
      margin: 1.5em 0;
      color: #4a4a4a;
      font-style: italic;
    }
    article ul, article ol { margin-bottom: 1.25em; padding-left: 1.5em; }
    article li { margin-bottom: 0.3em; }
    article code { font-family: 'JetBrains Mono', monospace; font-size: 0.9em; background: #f0ece6; padding: 0.1em 0.3em; border-radius: 3px; }
    a { color: #b5463e; text-decoration: none; }
    a:hover { text-decoration: underline; }
    /* Utility classes */
    .text-ink { color: #1a1a1a; }
    .text-ink-light { color: #4a4a4a; }
    .text-ink-muted { color: #8a8a8a; }
    .text-accent { color: #b5463e; }
    .bg-paper-warm { background: #f5f0eb; }
  </style>
  <slot name="head" />
</head>
<body class="min-h-screen">
  <header class="border-b border-[#e0dcd5] bg-white/80 backdrop-blur sticky top-0 z-10">
    <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="text-lg font-semibold no-underline hover:no-underline">
        🏛 半人马熵减实验室
      </a>
      <div class="flex gap-4 text-sm text-ink-light">
        <a href="/" class="hover:text-ink">首页</a>
        <a href="/about" class="hover:text-ink">关于</a>
      </div>
    </nav>
  </header>

  <main class="max-w-3xl mx-auto px-4 py-8">
    <slot />
  </main>

  <footer class="border-t border-[#e0dcd5] py-8 mt-12">
    <div class="max-w-3xl mx-auto px-4 text-sm text-ink-muted">
      <p>© 2026 半人马熵减实验室 — 大消费品 & 零售全球化组织治理洞察</p>
      <p class="mt-1">框架洞见，现地现物。</p>
    </div>
  </footer>
</body>
</html>