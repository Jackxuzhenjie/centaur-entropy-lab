---
import type { CollectionEntry } from 'astro:content';

const { article } = Astro.props;
const { Content } = await article.render();
const { title, date, category, excerpt, seo_keywords } = article.data;
const ogImage = article.data.og_image || '/og-default.png';
const keywords = seo_keywords?.join(', ') || title;
---

<article class="max-w-2xl mx-auto">
  <header class="mb-10">
    <a href="/" class="text-xs text-accent font-medium uppercase tracking-wide hover:underline">{category}</a>
    <h1 class="text-3xl font-semibold mt-2 mb-4">{title}</h1>
    <time class="text-sm text-ink-muted" datetime={date.toISOString()}>
      {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </header>

  <div class="prose">
    <Content />
  </div>

  <hr class="my-10 border-[#e0dcd5]" />

  <footer class="text-sm text-ink-muted space-y-2">
    <p><strong>信息披露</strong>：本文基于公开信息撰写，不构成投资建议。</p>
    <p><strong>方法论</strong>：预决分离 · 组织三空间框架</p>
  </footer>
</article>

<nav class="max-w-2xl mx-auto mt-16 pt-8 border-t border-[#e0dcd5]">
  <a href="/" class="text-sm text-accent hover:underline">← 返回首页</a>
</nav>